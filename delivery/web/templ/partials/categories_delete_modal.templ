package partials

import (
	"git.at.oechsler.it/samuel/dash/v2/delivery/web/templ/components"
	"fmt"
	"github.com/invopop/ctxi18n/i18n"
)

type CategoriesDeleteModalInput struct {
	ID          uint
	DisplayName string
}

templ CategoriesDeleteModal(input CategoriesDeleteModalInput) {
	@components.ModalDelete(components.ModalDeleteInput{
		DisplayName:  input.DisplayName,
		ResourceName: i18n.T(ctx, "sections.bookmarks"),
		DeleteAction: "/categories/" + fmt.Sprint(input.ID),
	})
}
