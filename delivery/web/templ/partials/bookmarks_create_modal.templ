package partials

import (
	"git.at.oechsler.it/samuel/dash/v2/delivery/web/templ/components"
	"fmt"
	"github.com/invopop/ctxi18n/i18n"
)

type BookmarksCreateModalInput struct {
	CategoryID          uint
	CategoryDisplayName string
	IconTypes           components.ModalUpserInputIconTypes
}

templ BookmarksCreateModal(input BookmarksCreateModalInput) {
	@components.ModalUpsert(components.ModalUpsertInput{
		ModalInput: components.ModalInput{
			Title: i18n.T(ctx, "modal_titles.create_bookmark_in", i18n.M{"category": input.CategoryDisplayName}),
		},
		SubmitAction:     "/bookmarks",
		SubmitActionType: components.ModalUpsertSubmitActionPost,
		IconTypes:        input.IconTypes,
	}) {
		<input type="hidden" name="category_id" value={ fmt.Sprint(input.CategoryID) }/>
	}
}
