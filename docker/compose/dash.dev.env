# Database
DATABASE_URL=postgresql://dash:devpassword@localhost:5432/dash?sslmode=disable

# OIDC provider (Dex - local dev)
OIDC_ISSUER=http://localhost:5556/dex
OIDC_CLIENT_ID=dash
OIDC_CLIENT_SECRET=dash-local-secret
OIDC_REDIRECT_URL=http://localhost:8080/session/login/callback
OIDC_SCOPES=openid profile email

# Authorization — * grants admin to every authenticated user
OIDC_ADMIN_GROUP=*

# Session cookie
# These are static dev-only secrets — do not use in production
OIDC_COOKIE_HASH_KEY=f56a8e90ede66dfc1a3023f63e8f158d7c17a55fabf36b7bdb75515488843c26ef88d27384626b1af895cc263c935b4c7191af23d13a7e2a56e35565c6f553d4
OIDC_COOKIE_BLOCK_KEY=939f95822ce7f554ad4e319490a5464ee9dc47f65063ccb6a53c0765ae737b4a
OIDC_COOKIE_NAME=dash-session
OIDC_COOKIE_DOMAIN=
OIDC_COOKIE_SECURE=false
OIDC_COOKIE_MAX_AGE=0

# Server
APP_PORT=8080
APP_ENV=dev
